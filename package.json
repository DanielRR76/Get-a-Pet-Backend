{
    "name": "backend",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "tsup src/server.ts --watch --onSuccess \"npm run start\"",
        "vercel-build": "npm run generate && npm run migrate:deploy && npm run build",
        "build": "tsup src/server.ts",
        "prod": "npm run build && npm run start",
        "generate": "npx prisma generate",
        "migrate:deploy": "npx prisma migrate deploy",
        "migrate:dev": "npx prisma migrate dev",
        "migrate:reset": "npx prisma migrate reset",
        "lint": "eslint \"src/**/*.ts\" --fix",
        "compose:up": "docker-compose up --build",
        "compose:down": "docker-compose down -v"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.1",
        "@prisma/client": "^7.4.1",
        "bcrypt": "^6.0.0",
        "braces": "^3.0.3",
        "cloudinary": "^2.9.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.0.2",
        "pg": "^8.19.0",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "github:eslint/eslintrc",
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.3.0",
        "@types/pg": "^8.16.0",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-unused-imports": "^4.4.1",
        "globals": "^17.3.0",
        "prettier": "3.8.1",
        "prisma": "^7.4.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1"
    }
}
